- path: readme.md
source:
- path: app.c
- path: app_iostream_usart.c
include:
- path: .
  file_list:
  - path: app.h
  - path: app_iostream_usart.h
sdk:
  vendor: null
  id: simplicity_sdk
  version: 2025.6.3
toolchain_settings:
- value: -Wall -Werror
  option: gcc_compiler_option
component:

  id: SIWG917Y121MGABA
- from: wiseconnect3_sdk
  id: iostream_si91x
- from: wiseconnect3_sdk
  id: si91x_memory_default_config
- from: wiseconnect3_sdk
  id: sl_usart_iostream
- id: atomic
- id: iostream_retarget_stdio
- instance:
